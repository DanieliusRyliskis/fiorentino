---
interface Props {
name:string;
size:string
alt:string;
}

const {name,size, alt} = Astro.props
---
<picture>
    <source srcset={`../../public/${name}.webp`} type="image/webp" />
    <img
        class={`w-full ${size} lg:object-cover cursor-pointer`}
        loading="lazy"
        src={`../../public/${name}.jpg`}
        alt={alt}
        data-name={name}
    />
</picture>

